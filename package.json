{
  "name": "needle",
  "version": "0.1.0",
  "description": "Local-first video subscription manager for YouTube and Bilibili with subtitle and AI summary pipelines.",
  "private": false,
  "author": "Needle contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Max-dwd/folo.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:docker": "next build --webpack",
    "start": "next start",
    "stop": "node scripts/stop.mjs",
    "restart": "npm run stop && git pull && npm run build && npm run start",
    "lint": "eslint",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "backup": "node scripts/backup.mjs",
    "restore": "node scripts/restore.mjs",
    "export:summary-md": "node scripts/export-subtitle-markdown.mjs",
    "browser:runtime:build": "npm --prefix browser-runtime run build",
    "browser:runtime:typecheck": "npm --prefix browser-runtime run typecheck",
    "browser:runtime:test": "npm --prefix browser-runtime run test",
    "browser:runtime:prepare": "npm run browser:runtime:build",
    "browser:prepare": "npm run browser:runtime:prepare && npm run browser:bridge:prepare",
    "browser:bridge:build": "npm --prefix browser-bridge/extension run build",
    "browser:bridge:typecheck": "npm --prefix browser-bridge/extension run typecheck",
    "browser:bridge:test": "npm --prefix browser-bridge/extension run test",
    "browser:bridge:package": "npm --prefix browser-bridge/extension run package:release",
    "browser:bridge:prepare": "npm run browser:bridge:build && npm run browser:bridge:package",
    "mcp:start": "tsx src/mcp-server/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/postcss": "^4.2.2",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "postcss": "^8.5.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tar": "^7.5.13",
    "ws": "^8.18.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chrome": "^0.0.287",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "@types/xml2js": "^0.4.14",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  }
}
